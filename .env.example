VITE_POKEMON_TCG_API_BASE_URL=https://api.pokemontcg.io/v2
POKEMON_TCG_API_KEY=

# Optional server-only LLM/OCR features. Keep OPENAI_API_KEY out of VITE_*.
# Leave the VITE_* mode flags unset/empty to run CardDex as a local demo.
VITE_CARD_ASSISTANT_MODE=local
VITE_SCANNER_OCR_MODE=local
VITE_SCANNER_VECTOR_MODE=disabled
VITE_SYNERGY_FEED_MODE=local
VITE_TELEMETRY_MODE=local
ENABLE_SERVER_AI_FEATURES=false
OPENAI_API_KEY=
ENABLE_TELEMETRY=false
RATE_LIMIT_SALT=
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Opcional: Base de datos en la nube (perfiles públicos y sincronización).
# Si no están presentes, la colección seguirá funcionando perfectamente usando LocalStorage.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
